
#include <stdlib.h>
#include <stdbool.h>
bool containsNearbyDuplicate(int* nums, int numsSize, int k) {
    int i,j;
    for(i=0;i<numsSize;i++){
        for(j=i+1;j<numsSize;j++){
            if(nums[i]==nums[j] && abs(i-j)<=k){
                return true;
            }
        }
    }
    return false;
}
