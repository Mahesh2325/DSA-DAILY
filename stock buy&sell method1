int maxProfit(int* prices, int pricesSize) {
    int maxprof=0,profit;
    for(int i=0;i<pricesSize;i++){
        for(int j=i+1;j<pricesSize;j++){
            profit=prices[j]-prices[i];
        
        if(profit>maxprof){
            maxprof=profit;
        }
        
    }
    }
    return maxprof;
}

